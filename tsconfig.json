{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@devvit/public-api"
  },
  "include": ["src/**/*.ts"]
}
